{
  "headers": [
    {
      "source": "/js/(.*).js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, s-maxage=0" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/telegram-cron",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cotacao-cron",
      "schedule": "0 22 * * 1-5"
    }
  ]
}
